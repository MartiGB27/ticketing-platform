# Consumed directly by docker-compose.yml (variable substitution) when you
# run `docker compose up`. Copy this to `.env` in this same folder.
# Every value already has a sensible default baked into docker-compose.yml,
# so this file is mainly here so you have one place to change secrets.

DB_USER=ticketing
DB_PASSWORD=ticketing_dev_password
DB_NAME=ticketing_db

JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=1h
