{
  "info": {
    "name": "Ticketing Platform",
    "description": "Collection to test Users, Auth, Events and Reservations. Import it and set the {{baseUrl}} variable to http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "reservationId", "value": "" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Jane Doe\"\n}"
            }
          }
        },
        {
          "name": "Get by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/REPLACE_WITH_USER_ID"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) { pm.collectionVariables.set('accessToken', data.accessToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Me (protected)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Create event",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) { pm.collectionVariables.set('eventId', data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/events",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Summer Music Festival\",\n  \"venue\": \"Downtown Arena\",\n  \"eventDate\": \"2026-09-15T21:00:00Z\",\n  \"totalTickets\": 100,\n  \"price\": 45.50\n}"
            }
          }
        },
        {
          "name": "List all events (public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "Get event by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/{{eventId}}"
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Create reservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) { pm.collectionVariables.set('reservationId', data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/reservations",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "My reservations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/reservations"
          }
        },
        {
          "name": "Get reservation by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/reservations/{{reservationId}}"
          }
        }
      ]
    }
  ]
}
