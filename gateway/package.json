{
  "name": "gateway",
  "version": "0.1.0",
  "description": "Phase 2 - API Gateway: single entry point, routes to backend services, fail-fast JWT check",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/jsonwebtoken": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
