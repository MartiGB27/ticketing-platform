PORT=3000

# Must be the SAME secret users-service uses to sign tokens.
JWT_SECRET=change_this_secret_in_production

# Inside Docker Compose, these resolve via the internal service names on
# their container port (3000). Outside Docker (running the gateway alone
# with `npm run start:dev`), point these at wherever you've started each
# service locally instead, e.g. http://localhost:3001.
USERS_SERVICE_URL=http://users-service:3000
EVENTS_SERVICE_URL=http://events-service:3000
RESERVATIONS_SERVICE_URL=http://reservations-service:3000
