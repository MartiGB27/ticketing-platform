# Server
PORT=3000

# PostgreSQL — same physical database as events-service for now (see the
# doc comment on EventRef for why).
DB_HOST=localhost
DB_PORT=5432
DB_USER=ticketing
DB_PASSWORD=ticketing_dev_password
