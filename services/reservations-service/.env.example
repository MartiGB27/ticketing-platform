# Server
PORT=3000

# PostgreSQL — same physical database as events-service for now (see the
# doc comment on EventRef for why).
DB_HOST=localhost
DB_PORT=5432
DB_USER=ticketing
DB_PASSWORD=ticketing_dev_password
DB_NAME=ticketing_db

# JWT — must match the SAME secret users-service uses to sign tokens.
JWT_SECRET=change_this_secret_in_production

# Redis — used for the 5-minute seat hold and for idempotency keys on
# the /confirm endpoint.
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ — used to publish 'reservation.confirmed' events for
# notifications-service to pick up.
RABBITMQ_URL=amqp://localhost:5672
