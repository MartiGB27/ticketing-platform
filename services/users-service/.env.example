# Server
PORT=3000

# PostgreSQL
# NOTE: when running via `docker compose up`, these DB_* values are
# injected directly by docker-compose.yml (using the root .env). This file
# is what you need if you want to run this service standalone with
# `npm run start:dev`, pointing at the Postgres container via its
# host-mapped port instead of the internal Docker network.
DB_HOST=localhost
DB_PORT=5432
DB_USER=ticketing
DB_PASSWORD=ticketing_dev_password
DB_NAME=ticketing_db

# JWT — must be the SAME secret across every service (users-service signs
# tokens, events-service/reservations-service/gateway verify them).
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=1h
