# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Resend (https://resend.com) — OPTIONAL. Leave empty to run in dry-run
# mode: every notification is logged to the console instead of actually
# sent, which is enough to test the full RabbitMQ -> consume -> "send"
# pipeline without signing up for anything.
#
# To send real emails: create a free Resend account, verify a sending
# domain (or use their default onboarding@resend.dev for testing), grab
# an API key, and set it below.
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=onboarding@resend.dev
